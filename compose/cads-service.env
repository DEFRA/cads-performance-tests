ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:5555
AWS__ServiceURL=http://localstack:4566
LOCALSTACK_ENDPOINT=http://localstack:4566
Postgres__DefaultConnection=Host=postgres;Port=5432;Database=cads_data_service;Username=postgres;Password=postgres;
Postgres__ReadOnlyConnection=Host=postgres;Port=5432;Database=cads_data_service;Username=postgres;Password=postgres;
Modules__Ingester__Queues__CadsCds__QueueUrl=http://localstack:4566/000000000000/cads-cds-queue
Modules__Ingester__Queues__CadsCds__DlqQueueUrl=http://localstack:4566/000000000000/cads-cds-queue-deadletter
Modules__Ingester__Storage__CadsIngester__BucketName=cads-internal-bucket
Modules__StorageBridge__Storage__CadsInternal__BucketName=cads-internal-bucket
Modules__StorageBridge__Storage__CadsInternal__HealthcheckEnabled=true
Modules__StorageBridge__Storage__CadsExternal__BucketName=cads-external-bucket
Modules__StorageBridge__Storage__CadsExternal__HealthcheckEnabled=true
AuthenticationConfiguration__ApiKey__Enabled=true
AuthenticationConfiguration__Cognito__Enabled=false
AuthenticationConfiguration__AzureAD__Enabled=false
REDIS_HOST=redis
USE_SINGLE_INSTANCE_CACHE=true
